{script:card1.7}
on pick verb who do
 action.text:verb
 textField.text:"You clicked %s" format verb
 cursors:("move","take","use","look","talk") dict ("drag","point","crosshair","default","default")
 app.cursor:cursors[verb]
 each b in (moveButton,takeButton,useButton,lookButton,talkButton)
  b.show:"solid"
 end
 who.show:"invert"
end
{end}

